# Optional defaults for the Design assistant (OpenAI-compatible chat completions).
# Copy to `.env` and set values; Vite exposes only variables prefixed with VITE_.
# The app also persists endpoint, key, and model in localStorage from the UI.
#
# Example: VITE_POP_AI_URL=https://api.openai.com/v1/chat/completions
# Example: VITE_POP_AI_MODEL=gpt-4o-mini

VITE_POP_AI_URL=
VITE_POP_AI_KEY=
VITE_POP_AI_MODEL=
