# Optional defaults for the Design assistant (Google Gemini via AI Studio).
# Copy to `.env` and set values; Vite exposes only variables prefixed with VITE_.
# The app also persists key and model choice in localStorage from the UI.
#
# Example: VITE_POP_AI_MODEL=gemini-2.5-flash

VITE_POP_AI_KEY=
VITE_POP_AI_MODEL=
